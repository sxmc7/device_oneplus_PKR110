# TWRP/OrangeFox partition flags for OnePlus PKR110 (SM8750 / sun)
# Dynamic partitions (qti_dynamic_partitions)
/system_image   emmc    /dev/block/bootdevice/by-name/system     flags=slotselect
/system_ext     emmc    /dev/block/bootdevice/by-name/system_ext flags=slotselect
/product        emmc    /dev/block/bootdevice/by-name/product    flags=slotselect
/vendor         emmc    /dev/block/bootdevice/by-name/vendor     flags=slotselect
/odm            emmc    /dev/block/bootdevice/by-name/odm        flags=slotselect
/vendor_dlkm    emmc    /dev/block/bootdevice/by-name/vendor_dlkm    flags=slotselect
/system_dlkm    emmc    /dev/block/bootdevice/by-name/system_dlkm    flags=slotselect

# Super partition (logical container)
/super          emmc    /dev/block/bootdevice/by-name/super      flags=slotselect

# Metadata partition
/metadata       ext4    /dev/block/bootdevice/by-name/metadata

# Boot partitions
/boot           emmc    /dev/block/bootdevice/by-name/boot            flags=slotselect;flashimg
/init_boot      emmc    /dev/block/bootdevice/by-name/init_boot       flags=slotselect;flashimg
/vendor_boot    emmc    /dev/block/bootdevice/by-name/vendor_boot     flags=slotselect;flashimg

# Verified Boot
/dtbo           emmc    /dev/block/bootdevice/by-name/dtbo            flags=slotselect;flashimg
/vbmeta         emmc    /dev/block/bootdevice/by-name/vbmeta          flags=slotselect;flashimg
/vbmeta_system  emmc    /dev/block/bootdevice/by-name/vbmeta_system   flags=slotselect;flashimg
/vbmeta_vendor  emmc    /dev/block/bootdevice/by-name/vbmeta_vendor   flags=slotselect;flashimg

# Userdata
/data           f2fs    /dev/block/bootdevice/by-name/userdata

# Persist
/persist        ext4    /dev/block/bootdevice/by-name/persist

# Cache
/cache          ext4    /dev/block/bootdevice/by-name/cache

# Misc
/misc           emmc    /dev/block/bootdevice/by-name/misc

# Firmware partitions
/firmware       vfat    /dev/block/bootdevice/by-name/modem           flags=slotselect;mounttodecrypt
/modem          emmc    /dev/block/bootdevice/by-name/modem           flags=slotselect;flashimg
/bluetooth      emmc    /dev/block/bootdevice/by-name/bluetooth       flags=slotselect;flashimg
/dsp            emmc    /dev/block/bootdevice/by-name/dsp             flags=slotselect;flashimg

# Oplus partitions
/oplus_boot     emmc    /dev/block/bootdevice/by-name/oplus_boot      flags=slotselect;flashimg
/oplus_dycfg    emmc    /dev/block/bootdevice/by-name/oplus_dycfg     flags=slotselect;flashimg

# FRP
/frp            emmc    /dev/block/bootdevice/by-name/frp

# EFS (backup only)
/efs1           emmc    /dev/block/bootdevice/by-name/efs             flags=backup;subpartitionof=/efs
/efs2           emmc    /dev/block/bootdevice/by-name/efs_backup      flags=backup;subpartitionof=/efs

# Removable storage
/usb_otg        auto    /dev/block/sd*                                flags=removable
